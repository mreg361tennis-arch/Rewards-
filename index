                    <label for="self-${index}-${i}"></label>`;
                }
                html += `</div></div>`;

                html += `<div class="star-rating-group">
                    <span class="star-rating-label">Mom/Dad Rating:</span>
                    <div class="star-rating">`;
                for (let i = 5; i >= 1; i--) {
                    html += `<input type="radio" id="parent-${index}-${i}" name="parent-${index}" value="${i}">
                    <label for="parent-${index}-${i}"></label>`;
                }
                html += `</div>
                    <span class="rating-average" id="avg-${index}">Avg: -</span>
                </div>`;

                dayDiv.innerHTML = html;
                container.appendChild(dayDiv);

                // Attach listeners AFTER appending so elements exist in the DOM
                ['self', 'parent'].forEach(type => {
                    for (let starVal = 1; starVal <= 5; starVal++) {
                        const input = document.getElementById(`${type}-${index}-${starVal}`);
                        if (!input) continue;

                        input.addEventListener('click', (function(t, idx, val) {
                            return function() {
                                const saved = JSON.parse(localStorage.getItem('ratings') || '{}');
                                const dayData = saved[idx] || {};
                                if (String(dayData[t]) === String(val)) {
                                    this.checked = false;
                                }
                                saveRatings();
                            };
                        })(type, index, starVal));
                    }
                });
            });
        }

        function saveRatings() {
  
            const ratings = {};  
              
            for (let i = 0; i < 7; i++) {  
                const selfInputs = document.querySelectorAll(`input[name="self-${i}"]:checked`);  
                const parentInputs = document.querySelectorAll(`input[name="parent-${i}"]:checked`);  
                  
                const selfRating = selfInputs.length > 0 ? selfInputs[0].value : '';  
                const parentRating = parentInputs.length > 0 ? parentInputs[0].value : '';  
                  
                ratings[i] = { self: selfRating, parent: parentRating };  
                  
                // Update average display based on the newly constructed object  
                const avgDiv = document.getElementById(`avg-${i}`);  
                const r = ratings[i];  
                if (r.self && r.parent) {  
                    const avg = (parseFloat(r.self) + parseFloat(r.parent)) / 2;  
                    avgDiv.textContent = `Avg: ${avg.toFixed(1)}`;  
                    avgDiv.className = avg >= 4 ? 'rating-average high' : 'rating-average low';  
                } else {  
                    avgDiv.textContent = 'Avg: -';  
                    avgDiv.className = 'rating-average';  
                }  
            }  
              
            localStorage.setItem('ratings', JSON.stringify(ratings));  
            updateProjectedEarnings();
        }  
          
        function loadRatings() {  
            const saved = localStorage.getItem('ratings');  
            if (saved) {  
                const ratings = JSON.parse(saved);  
                  
                for (let i = 0; i < 7; i++) {  
                    if (ratings[i]) {  
                        if (ratings[i].self) {  
                            const selfRadio = document.getElementById(`self-${i}-${ratings[i].self}`);  
                            if (selfRadio) selfRadio.checked = true;  
                        }  
                        if (ratings[i].parent) {  
                            const parentRadio = document.getElementById(`parent-${i}-${ratings[i].parent}`);  
                            if (parentRadio) parentRadio.checked = true;  
                        }  
                    }  
                }  
                  
                saveRatings(); // Recalc averages  
            }  
        }  
          
        function clearRatings() {  
            for (let i = 0; i < 7; i++) {  
                const selfInputs = document.querySelectorAll(`input[name="self-${i}"]`);  
                const parentInputs = document.querySelectorAll(`input[name="parent-${i}"]`);  
                  
                selfInputs.forEach(input => input.checked = false);  
                parentInputs.forEach(input => input.checked = false);  
                  
                const avgDiv = document.getElementById(`avg-${i}`);  
                if (avgDiv) {  
                    avgDiv.textContent = 'Avg: -';  
                    avgDiv.className = 'rating-average';  
                }  
            }  
              
            localStorage.setItem('ratings', JSON.stringify({}));  
            updateProjectedEarnings();
            showModal('Success', 'All ratings have been cleared!');  
        }  
          
        // Updates Management  
        function addUpdate() {  
            const input = document.getElementById('newUpdate');  
            const text = input.value.trim();  
              
            if (text === '') {  
                showModal('Error', 'Please enter an update!', true);  
                return;  
            }  
              
            const li = document.createElement('li');  
            li.className = 'update-item';  
            li.innerHTML = `<span>${text}</span><button class="btn btn-delete" onclick="deleteUpdate(this)">Delete</button>`;  
              
            document.getElementById('updatesList').appendChild(li);  
            input.value = '';  
            saveUpdates();  
        }  
          
        function deleteUpdate(button) {  
            button.parentElement.remove();  
            saveUpdates();  
        }  
          
        function saveUpdates() {  
            const updates = [];  
            document.querySelectorAll('.update-item span').forEach(span => {  
                updates.push(span.textContent);  
            });  
            localStorage.setItem('updates', JSON.stringify(updates));  
        }  
          
        function loadUpdates() {  
            const saved = localStorage.getItem('updates');  
            if (saved) {  
                const updates = JSON.parse(saved);  
                const list = document.getElementById('updatesList');  
                list.innerHTML = '';  
                  
                updates.forEach(update => {  
                    const li = document.createElement('li');  
                    li.className = 'update-item';  
                    li.innerHTML = `<span>${update}</span><button class="btn btn-delete" onclick="deleteUpdate(this)">Delete</button>`;  
                    list.appendChild(li);  
                });  
            }  
        }  
          
        // View Toggle  
        function toggleView() {  
            const body = document.body;  
            const btn = document.getElementById('toggleBtn');  
              
            if (body.classList.contains('mobile-view')) {  
                body.classList.remove('mobile-view');  
                btn.textContent = '📱 Mobile View';  
                localStorage.setItem('viewMode', 'desktop');  
            } else {  
                body.classList.add('mobile-view');  
                btn.textContent = '💻 Desktop View';  
                localStorage.setItem('viewMode', 'mobile');  
            }  
        }  
          
        function loadViewPreference() {  
            const saved = localStorage.getItem('viewMode');  
            if (saved === 'mobile') {  
                document.body.classList.add('mobile-view');  
                document.getElementById('toggleBtn').textContent = '💻 Desktop View';  
            }  
        }  
          
        // Export/Import  
                // Projected Earnings Calculator
        function updateProjectedEarnings() {

            // Sleep
            let sleepCount = 0;
            for (let i = 1; i <= 7; i++) {
                if (document.getElementById('sleep' + i) && document.getElementById('sleep' + i).checked) sleepCount++;
            }
            let sleepEarnings = 0;
            let sleepNote = 'Need 5+ days to earn';
            if (sleepCount === 7) { sleepEarnings = 10; sleepNote = 'Perfect week!'; }
            else if (sleepCount === 6) { sleepEarnings = 8; sleepNote = '6/7 days'; }
            else if (sleepCount >= 5) { sleepEarnings = 6; sleepNote = '5/7 days'; }
            setProj('sleep', sleepEarnings, sleepNote);

            // On-Time
            let ontimeCount = 0;
            for (let i = 1; i <= 7; i++) {
                if (document.getElementById('ontime' + i) && document.getElementById('ontime' + i).checked) ontimeCount++;
            }
            let ontimeEarnings = 0;
            let ontimeNote = 'Need 5+ days to earn';
            if (ontimeCount === 7) { ontimeEarnings = 10; ontimeNote = 'Perfect week!'; }
            else if (ontimeCount === 6) { ontimeEarnings = 8; ontimeNote = '6/7 days'; }
            else if (ontimeCount >= 5) { ontimeEarnings = 6; ontimeNote = '5/7 days'; }
            setProj('ontime', ontimeEarnings, ontimeNote);

            // Shoulder
            // Category 1: Basic (need 5). Category 2: IYT (need 3) + ROM (need 2).
            // $10: perfect (all done). $7: miss at most 1 from each category. $0: otherwise.
            let basicCount = 0, iytCount = 0, romCount = 0;
            for (let i = 1; i <= 5; i++) { if (document.getElementById('basic' + i) && document.getElementById('basic' + i).checked) basicCount++; }
            for (let i = 1; i <= 3; i++) { if (document.getElementById('iyt' + i) && document.getElementById('iyt' + i).checked) iytCount++; }
            for (let i = 1; i <= 2; i++) { if (document.getElementById('rom' + i) && document.getElementById('rom' + i).checked) romCount++; }
            const basicShort = Math.max(0, 5 - basicCount);
            const iytRomShort = Math.max(0, 3 - iytCount) + Math.max(0, 2 - romCount);
            let shoulderEarnings = 0;
            let shoulderNote = 'Complete exercises to earn';
            if (basicShort === 0 && iytRomShort === 0) { shoulderEarnings = 10; shoulderNote = 'Perfect! All exercises done'; }
            else if (basicShort <= 1 && iytRomShort <= 1) { shoulderEarnings = 7; shoulderNote = 'Normal pay (1 missed per category)'; }
            setProj('shoulder', shoulderEarnings, shoulderNote);

            // Piano
            let pianoTotal = 0;
            for (let i = 1; i <= 7; i++) {
                const v = parseFloat(document.getElementById('piano' + i) ? document.getElementById('piano' + i).value : 0) || 0;
                pianoTotal += v;
            }
            let pianoEarnings = 0;
            let pianoNote = 'Need 10+ hrs to earn';
            if (pianoTotal >= 11) { pianoEarnings = 15; pianoNote = pianoTotal.toFixed(1) + ' hrs (11+ tier)'; }
            else if (pianoTotal >= 10) { pianoEarnings = 13; pianoNote = pianoTotal.toFixed(1) + ' hrs (10+ tier)'; }
            setProj('piano', pianoEarnings, pianoNote);

            // Running
            let runningTotal = 0;
            for (let i = 1; i <= 7; i++) {
                const v = parseFloat(document.getElementById('running' + i) ? document.getElementById('running' + i).value : 0) || 0;
                runningTotal += v;
            }
            let runningEarnings = 0;
            let runningNote = 'Need 1.5+ hrs to earn';
            if (runningTotal >= 2.0) { runningEarnings = 8; runningNote = runningTotal.toFixed(1) + ' hrs (2hr tier)'; }
            else if (runningTotal >= 1.5) { runningEarnings = 5; runningNote = runningTotal.toFixed(1) + ' hrs (1.5hr tier)'; }
            setProj('running', runningEarnings, runningNote);

            // Follow Directions (from star ratings)
            let daysAbove4 = 0;
            for (let i = 0; i < 7; i++) {
                const selfInputs = document.querySelectorAll(`input[name="self-${i}"]:checked`);
                const parentInputs = document.querySelectorAll(`input[name="parent-${i}"]:checked`);
                if (selfInputs.length > 0 && parentInputs.length > 0) {
                    const avg = (parseFloat(selfInputs[0].value) + parseFloat(parentInputs[0].value)) / 2;
                    if (avg >= 4) daysAbove4++;
                }
            }
            let directionsEarnings = 0;
            let directionsNote = 'Need 5+ days at 4 stars';
            if (daysAbove4 === 7) { directionsEarnings = 16; directionsNote = '7 days rated 4+'; }
            else if (daysAbove4 === 6) { directionsEarnings = 13; directionsNote = '6 days rated 4+'; }
            else if (daysAbove4 >= 5) { directionsEarnings = 10; directionsNote = '5 days rated 4+'; }
            setProj('directions', directionsEarnings, directionsNote);

            // Total (excluding teachers since it's manual)
            const total = sleepEarnings + ontimeEarnings + shoulderEarnings + pianoEarnings + runningEarnings + directionsEarnings;
            document.getElementById('totalProjected').textContent = total.toFixed(0);
        }

        function setProj(id, amount, note) {
            const box = document.getElementById('proj-' + id);
            const amountEl = document.getElementById('proj-' + id + '-amount');
            const noteEl = document.getElementById('proj-' + id + '-note');
            if (!box || !amountEl) return;
            amountEl.textContent = '$' + amount;
            if (noteEl) noteEl.textContent = note;
            if (amount > 0) {
                box.classList.remove('zero');
            } else {
                box.classList.add('zero');
            }
        }

        function addProjectedToBalance() {
            const projectedText = document.getElementById('totalProjected').textContent;
            const projected = parseFloat(projectedText) || 0;
            if (projected === 0) {
                showModal('Notice', 'No projected earnings to add yet. Complete your tasks first!', true);
                return;
            }
            const currentBalance = parseFloat(document.getElementById('currentBalance').textContent) || 0;
            const newBalance = (currentBalance + projected).toFixed(2);
            document.getElementById('currentBalance').textContent = newBalance;
            document.getElementById('balanceInput').value = newBalance;
            localStorage.setItem('balance', newBalance);
            showModal('Success', 'Added $' + projected + ' in projected earnings to your balance! New balance: $' + newBalance);
        }

        // Enter key support  
        document.getElementById('balanceInput').addEventListener('keypress', (e) => {  
            if (e.key === 'Enter') saveBalance();  
        });  
          
        document.getElementById('newUpdate').addEventListener('keypress', (e) => {  
            if (e.key === 'Enter') addUpdate();  
        });  
    </script>  
</body>  
</html>  
