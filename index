        // ── JSONBin.io sync ──────────────────────────────────────────────────────
        const BIN_ID  = '6a137440ee5a733b1213796e';
        const API_KEY = '$2a$10$pRDnrzFydk5.dfcxLl.f..g/WhYkZIH/D4pcz823R6nocqtt58gCe';
        const BIN_URL = 'https://api.jsonbin.io/v3/b/' + BIN_ID;

        let cloudSaveTimer = null;
        let isSeeding = false;

        // Intercept every localStorage.setItem so any change auto-schedules a cloud save
        const _origSet = localStorage.setItem.bind(localStorage);
        localStorage.setItem = function(key, value) {
            _origSet(key, value);
            if (!isSeeding) scheduleCloudSave();
        };

        function setStatus(state, text) {
            const bar   = document.getElementById('driveStatus');
            const label = document.getElementById('driveStatusText');
            if (!bar || !label) return;
            bar.className = 'drive-status-bar ' + state;
            label.textContent = text;
        }

        function scheduleCloudSave() {
            setStatus('saving', 'Saving...');
            clearTimeout(cloudSaveTimer);
            cloudSaveTimer = setTimeout(() => pushToCloud(false), 1000);
        }

        function pushToCloud(manual) {
            const state = {
                balance:             localStorage.getItem('balance') || '0',
                sleepCheckboxes:     localStorage.getItem('sleepCheckboxes') || '{}',
                ontimeCheckboxes:    localStorage.getItem('ontimeCheckboxes') || '{}',
                exerciseCheckboxes:  localStorage.getItem('exerciseCheckboxes') || '{}',
                clothingCheckboxes:  localStorage.getItem('clothingCheckboxes') || '{}',
                pianoHours:          localStorage.getItem('pianoHours') || '{}',
                runningHours:        localStorage.getItem('runningHours') || '{}',
                ratings:             localStorage.getItem('ratings') || '{}',
                updates:             localStorage.getItem('updates') || '[]',
                viewMode:            localStorage.getItem('viewMode') || 'desktop',
            };
            fetch(BIN_URL, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Master-Key': API_KEY
                },
                body: JSON.stringify(state)
            })
            .then(r => {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(() => setStatus('idle', '✓ Saved'))
            .catch(err => setStatus('error', '✗ Save failed (' + err.message + ') — data kept locally'));
        }

        function loadFromCloud(callback) {
            setStatus('saving', 'Loading...');
            fetch(BIN_URL + '/latest', {
                headers: { 'X-Master-Key': API_KEY }
            })
            .then(r => r.json())
            .then(json => {
                const data = json.record || {};
                isSeeding = true;
                if (data.balance !== undefined)  _origSet('balance', data.balance);
                if (data.sleepCheckboxes)        _origSet('sleepCheckboxes', data.sleepCheckboxes);
                if (data.ontimeCheckboxes)       _origSet('ontimeCheckboxes', data.ontimeCheckboxes);
                if (data.exerciseCheckboxes)     _origSet('exerciseCheckboxes', data.exerciseCheckboxes);
                if (data.clothingCheckboxes)     _origSet('clothingCheckboxes', data.clothingCheckboxes);
                if (data.pianoHours)             _origSet('pianoHours', data.pianoHours);
                if (data.runningHours)           _origSet('runningHours', data.runningHours);
                if (data.ratings)                _origSet('ratings', data.ratings);
                if (data.updates)                _origSet('updates', data.updates);
                if (data.viewMode)               _origSet('viewMode', data.viewMode);
                setStatus('idle', '✓ Loaded from cloud');
                callback();
                isSeeding = false;
            })
            .catch(() => {
                setStatus('error', 'Could not reach cloud — loaded local data');
                callback();
            });
        }

